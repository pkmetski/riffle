<?xml version="1.0" encoding="utf-8"?>
<!--
  Bundled fallback for the LocalFiles Source. Every SourceType is required to
  have a bundled monogram so `SourceIconResolver.fallbackDrawableFor` stays
  exhaustive at compile time; picker call sites may still choose to render
  Material's Folder icon as their "coming from the OS" affordance, but the
  Settings Sources row and drawer entry use this drawable so the visual
  language across sources is consistent.
-->
