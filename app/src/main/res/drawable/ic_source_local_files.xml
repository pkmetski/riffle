        android:pathData="M12,0 A12,12 0 1 0 12,24 A12,12 0 1 0 12,0z"
        android:fillColor="#4B6584" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M5.5,8 L10.2,8 L11.7,9.5 L18.5,9.5 L18.5,17 L5.5,17 Z" />
